# Application Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=*

# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=skillsync
DATABASE_SSL=false
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false
DATABASE_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=skillsync
REDIS_CONNECT_TIMEOUT=10000

# Feature Flags
FEATURE_ENABLE_SWAGGER=true
FEATURE_ENABLE_CACHE=true
FEATURE_ENABLE_RATE_LIMITING=true
FEATURE_ENABLE_LOGGING=true

# Logging
LOG_LEVEL=log
LOG_FORMAT=simple
