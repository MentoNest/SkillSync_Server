# =============================================================================
# SkillSync Server Configuration
# =============================================================================

# Environment
NODE_ENV=development

# Server
PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=skillsync
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false
DATABASE_SSL=false
DATABASE_POOL_SIZE=10

# =============================================================================
# JWT Configuration
# =============================================================================

JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars
JWT_EXPIRES_IN=24h
JWT_ACCESS_EXPIRATION=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-minimum-32
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# Redis Configuration
# =============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=skillsync
REDIS_CONNECT_TIMEOUT=10000

# =============================================================================
# Feature Flags
# =============================================================================

FEATURE_ENABLE_SWAGGER=true
FEATURE_ENABLE_CACHE=true
FEATURE_ENABLE_RATE_LIMITING=true
FEATURE_ENABLE_LOGGING=true

# =============================================================================
# Seed Configuration
# =============================================================================

# Set to 'true' to disable automatic seeding on startup
DISABLE_SEED=false

# Admin wallet address for the default admin user
# This should be a valid Ethereum-compatible wallet address
DEFAULT_ADMIN_WALLET=0x742d35Cc6634C0532925a3b844Bc2e7c6A9A8B0F

# Set to 'true' to enable demo data seeding (development/staging only)
# Run 'npm run seed:demo' to manually seed demo accounts
SEED_DEMO_DATA=false

# =============================================================================
# Logging
# =============================================================================

LOG_LEVEL=log
LOG_FORMAT=simple
